rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.userId == request.auth.uid &&
             data.url is string && data.url.size() < 1000 &&
             data.name is string && data.name.size() < 100;
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidProject(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
